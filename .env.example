# Host-local database URL for tools run from your machine.
# Docker Compose overrides this with the postgres service hostname internally.
DATABASE_URL="postgresql://miniwallet:miniwallet@localhost:5432/miniwallet?schema=public"

# Reserved for Phase 4 auth. It is not used by the Phase 3 skeleton yet.
JWT_SECRET="replace-with-a-local-development-secret"

API_PORT=3000
WEB_PORT=5173
VITE_API_BASE_URL="http://localhost:3000"
