generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TransactionStatus {
  CONFIRMED
  PENDING_REVIEW
  REJECTED
}

enum RiskReason {
  AMOUNT_ABOVE_REVIEW_THRESHOLD
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum LedgerBalanceType {
  AVAILABLE
  PENDING
}

enum LedgerEntryType {
  TRANSFER_OUT
  TRANSFER_IN
  HOLD
  RELEASE
  REVERSAL
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet               Wallet?
  sentTransactions     Transaction[] @relation("SentTransactions")
  receivedTransactions Transaction[] @relation("ReceivedTransactions")
  reviewedTransactions Transaction[] @relation("ReviewedTransactions")
  auditLogs            AuditLog[]

  @@map("users")
}

model Wallet {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @db.Uuid
  availableBalanceCents BigInt  @default(0)
  pendingBalanceCents   BigInt  @default(0)
  currency             String   @default("USD")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTransactions     Transaction[] @relation("FromWalletTransactions")
  receivedTransactions Transaction[] @relation("ToWalletTransactions")
  ledgerEntries        LedgerEntry[]

  @@unique([id, userId])
  @@index([userId])
  @@map("wallets")
}

model Transaction {
  id           String            @id @default(uuid()) @db.Uuid
  amountCents  BigInt
  currency     String            @default("USD")
  status       TransactionStatus
  riskReason   RiskReason?
  fromUserId   String            @db.Uuid
  toUserId     String            @db.Uuid
  fromWalletId String            @db.Uuid
  toWalletId   String            @db.Uuid
  reviewedByUserId String?       @db.Uuid
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  confirmedAt  DateTime?
  reviewedAt   DateTime?

  fromUser       User          @relation("SentTransactions", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser         User          @relation("ReceivedTransactions", fields: [toUserId], references: [id], onDelete: Restrict)
  fromWallet     Wallet        @relation("FromWalletTransactions", fields: [fromWalletId, fromUserId], references: [id, userId], onDelete: Restrict)
  toWallet       Wallet        @relation("ToWalletTransactions", fields: [toWalletId, toUserId], references: [id, userId], onDelete: Restrict)
  reviewedByUser User?         @relation("ReviewedTransactions", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  ledgerEntries  LedgerEntry[]
  auditLogs      AuditLog[]

  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@index([status, createdAt])
  @@index([riskReason, createdAt])
  @@map("transactions")
}

model LedgerEntry {
  id            String            @id @default(uuid()) @db.Uuid
  transactionId String            @db.Uuid
  walletId      String            @db.Uuid
  direction     LedgerDirection
  balanceType   LedgerBalanceType
  entryType     LedgerEntryType
  amountCents   BigInt
  createdAt     DateTime          @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  wallet      Wallet      @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([walletId, createdAt])
  @@map("ledger_entries")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorUserId   String?  @db.Uuid
  action        String
  entityType    String
  entityId      String   @db.Uuid
  transactionId String?  @db.Uuid
  metadata      Json?
  createdAt     DateTime @default(now())

  actorUser   User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([transactionId])
  @@map("audit_logs")
}
